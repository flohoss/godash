{
  "license": "MIT",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/style.css --watch",
    "build": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/style.css --minify",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@iconify/json": "^2.2.503",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/cli": "^4.3.3",
    "daisyui": "^5.7.0",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.3"
  },
  "prettier": {
    "printWidth": 160,
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2,
    "useTabs": false,
    "trailingComma": "es5",
    "endOfLine": "lf",
    "bracketSpacing": true,
    "arrowParens": "always"
  }
}
