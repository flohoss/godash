{
  "watch": {
    "buildIndexJS": "./static/js/index.js",
    "buildLoginJS": "./static/js/login.js"
  },
  "scripts": {
    "watch": "npm-watch",
    "devTailwind": "npx tailwindcss -i ./static/css/input.css -o ./static/css/style.css --watch",
    "buildTailwind": "npx tailwindcss -i ./static/css/input.css -o ./static/css/style.css --minify",
    "buildIndexJS": "terser static/js/index.js -o ./static/js/index.min.js -c -m",
    "buildLoginJS": "terser static/js/login.js -o ./static/js/login.min.js -c -m",
    "dev": "bash -c \"npm run devTailwind &npm run watch\"",
    "build": "npm run buildTailwind && npm run buildIndexJS && npm run buildLoginJS"
  },
  "devDependencies": {
    "daisyui": "^2.33.0",
    "npm-watch": "^0.11.0",
    "prettier": "^2.7.1",
    "prettier-plugin-go-template": "^0.0.13",
    "tailwindcss": "^3.2.0",
    "terser": "^5.16.1"
  },
  "prettier": {
    "printWidth": 160,
    "goTemplateBracketSpacing": true
  }
}
